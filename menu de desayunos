print("=== MENÚ DE DESAYUNOS ===")
print("1. Desayuno continental")
print("2. Desayuno americano")
print("3. Desayuno inglés")

opcion = int(input("Seleccione una opción (1-3): "))

match opcion:
    case 1:
        print("Ha seleccionado desayuno continental.")
    case 2:
        print("Ha seleccionado desayuno americano.")
    case 3:
        print("Ha seleccionado desayuno inglés.")
    case _:
        print("Opción no válida. Intente nuevamente.")
